{
  "name": "client",
  "main": "expo-router/entry",
  "version": "1.0.0",
  "scripts": {
    "start": "expo start",
    "reset-project": "node ./scripts/reset-project.js",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "lint": "expo lint",
    "feature": "node ./scripts/generate-feature.js",
    "preprocess-svg": "node ./scripts/preprocess-svg.js",
    "build-icons": "node ./scripts/build-icons.js",
    "build-icons:force": "node ./scripts/build-icons.js --force",
    "generate-index": "node ./scripts/generate-index.js",
    "icons": "npm run preprocess-svg && npm run build-icons && npm run generate-index",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@expo/vector-icons": "^15.0.3",
    "@hookform/resolvers": "^5.2.2",
    "@react-native-community/netinfo": "^12.0.1",
    "@react-navigation/bottom-tabs": "^7.4.0",
    "@react-navigation/elements": "^2.6.3",
    "@react-navigation/native": "^7.1.8",
    "@tanstack/react-query": "^5.96.2",
    "axios": "^1.14.0",
    "expo": "~55.0.0",
    "expo-constants": "~55.0.11",
    "expo-device": "~55.0.12",
    "expo-font": "~55.0.6",
    "expo-haptics": "~55.0.11",
    "expo-image": "~55.0.8",
    "expo-linking": "~55.0.11",
    "expo-router": "~55.0.10",
    "expo-secure-store": "~55.0.11",
    "expo-splash-screen": "~55.0.15",
    "expo-status-bar": "~55.0.5",
    "expo-symbols": "~55.0.7",
    "expo-system-ui": "~55.0.13",
    "expo-web-browser": "~55.0.12",
    "react": "19.2.0",
    "react-dom": "19.2.0",
    "react-hook-form": "^7.72.1",
    "react-native": "0.83.4",
    "react-native-gesture-handler": "~2.30.0",
    "react-native-reanimated": "4.2.1",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.23.0",
    "react-native-svg": "15.15.3",
    "react-native-web": "~0.21.0",
    "react-native-worklets": "0.7.2",
    "zod": "^4.3.6",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@testing-library/react-hooks": "^8.0.1",
    "@testing-library/react-native": "^13.3.3",
    "@types/react": "~19.2.10",
    "@vitest/coverage-v8": "^4.1.3",
    "eslint": "^9.25.0",
    "eslint-config-expo": "~55.0.0",
    "msw": "^2.13.0",
    "react-test-renderer": "^19.2.0",
    "typescript": "~5.9.2",
    "vitest": "^4.1.3"
  },
  "private": true
}
