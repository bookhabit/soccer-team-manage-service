generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Enums ────────────────────────────────────────────────────────────────────

enum PlayerPosition {
  FW
  MF
  DF
  GK
}

// ─── Models ───────────────────────────────────────────────────────────────────

model User {
  id           String          @id @default(cuid())
  email        String          @unique
  passwordHash String
  nickname     String
  position     PlayerPosition?
  skillLevel   Int             @default(3) // 1~5
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt

  sessions Session[]

  @@map("users")
}

model Session {
  id               String   @id @default(cuid())
  userId           String
  refreshTokenHash String
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId])
  @@map("sessions")
}
