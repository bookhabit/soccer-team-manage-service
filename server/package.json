{
  "name": "soccer-team-app-server",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "dev": "nest start --watch",
    "build": "tsc -p tsconfig.build.json",
    "start": "node dist/main",
    "lint": "eslint src --max-warnings 0",
    "type-check": "tsc --noEmit",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:push": "prisma db push",
    "db:studio": "prisma studio",
    "db:seed": "ts-node --project tsconfig.json -e \"require('tsconfig-paths/register')\" prisma/seed.ts",
    "seed:club": "ts-node --project tsconfig.seed.json prisma/seeds/club.seed.ts",
    "seed:match": "ts-node --project tsconfig.seed.json prisma/seeds/match.seed.ts",
    "seed:matching": "ts-node --project tsconfig.seed.json prisma/seeds/matching.seed.ts",
    "seed:mercenary": "ts-node --project tsconfig.seed.json prisma/seeds/mercenary.seed.ts",
    "seed:match-feed": "ts-node --project tsconfig.seed.json prisma/seeds/match-feed.seed.ts",
    "seed:head-to-head": "ts-node --project tsconfig.seed.json prisma/seeds/head-to-head.seed.ts",
    "seed:file": "ts-node --project tsconfig.seed.json prisma/seeds/file.seed.ts",
    "seed:all": "ts-node --project tsconfig.seed.json prisma/seeds/index.seed.ts",
    "setup:data": "prisma migrate dev && npm run db:seed && npm run seed:all",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:e2e": "jest --testPathPattern=e2e"
  },
  "dependencies": {
    "@nestjs/common": "^10.4.0",
    "@nestjs/config": "^3.3.0",
    "@nestjs/core": "^10.4.0",
    "@nestjs/jwt": "^10.2.0",
    "@nestjs/passport": "^10.0.3",
    "@nestjs/platform-express": "^10.4.22",
    "@nestjs/serve-static": "^4.0.2",
    "@nestjs/swagger": "^7.4.2",
    "@nestjs/throttler": "^6.5.0",
    "@prisma/client": "^6.0.0",
    "@types/multer": "^2.1.0",
    "@types/uuid": "^10.0.0",
    "bcryptjs": "^3.0.3",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "cookie-parser": "^1.4.7",
    "helmet": "^8.1.0",
    "multer": "^2.1.1",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "sanitize-html": "^2.17.2",
    "sharp": "^0.34.5",
    "uuid": "^13.0.0"
  },
  "prisma": {
    "seed": "ts-node --project tsconfig.seed.json prisma/seed.ts"
  },
  "devDependencies": {
    "@nestjs/testing": "^10.4.0",
    "@types/bcryptjs": "^2.4.6",
    "@types/cookie-parser": "^1.4.10",
    "@types/express": "^5.0.0",
    "@types/jest": "^30.0.0",
    "@types/node": "^22.0.0",
    "@types/passport-jwt": "^4.0.1",
    "@types/sanitize-html": "^2.16.1",
    "@types/supertest": "^7.2.0",
    "jest": "^30.3.0",
    "prisma": "^6.0.0",
    "prisma-erd-generator": "^2.4.2",
    "supertest": "^7.2.2",
    "ts-jest": "^29.4.6",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.8.3"
  }
}
