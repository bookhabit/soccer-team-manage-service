erDiagram

%% ============================================================
%% FC Flow — Entity Relationship Diagram
%% 기준 문서: 04_screen_design.md / 02_feature_list.md
%% ============================================================

%% ─────────────────────────────────────────
%%  1. 인증 & 사용자
%% ─────────────────────────────────────────

users {
    int         id              PK
    string      email           UK
    string      password_hash
    string      nickname        UK
    string      real_name
    string      position
    string      preferred_foot
    int         jersey_number
    string      profile_image
    float       rating
    datetime    created_at
    datetime    deleted_at
}

refresh_tokens {
    int         id              PK
    int         user_id         FK
    string      token           UK
    string      platform
    datetime    expires_at
    datetime    created_at
}

fcm_tokens {
    int         id              PK
    int         user_id         FK
    string      token
    string      platform
    datetime    updated_at
}

notifications {
    int         id              PK
    int         user_id         FK
    string      type
    string      title
    string      body
    string      deep_link
    boolean     is_read
    datetime    created_at
}

%% ─────────────────────────────────────────
%%  2. 팀 관리
%% ─────────────────────────────────────────

teams {
    int         id              PK
    string      name            UK
    string      region
    int         level
    string      description
    string      logo_image
    int         captain_id      FK
    int         monthly_fee
    string      bank_account
    datetime    created_at
}

team_members {
    int         id              PK
    int         team_id         FK
    int         user_id         FK
    string      role
    datetime    joined_at
}

join_requests {
    int         id              PK
    int         team_id         FK
    int         user_id         FK
    string      status
    datetime    created_at
    datetime    processed_at
}

invite_links {
    int         id              PK
    int         team_id         FK
    string      code            UK
    datetime    expires_at
    datetime    created_at
}

position_setups {
    int         id              PK
    int         team_id         FK
    int         poll_id         FK
    string      formation
    string      positions_json
    datetime    updated_at
}

%% ─────────────────────────────────────────
%%  3. 게시판 & 회비
%% ─────────────────────────────────────────

board_posts {
    int         id              PK
    int         team_id         FK
    int         author_id       FK
    string      type
    string      title
    string      content
    boolean     send_fcm
    datetime    created_at
    datetime    deleted_at
}

post_comments {
    int         id              PK
    int         post_id         FK
    int         author_id       FK
    string      content
    datetime    created_at
}

team_fees {
    int         id              PK
    int         team_id         FK
    int         amount
    string      bank_account
    int         due_day
    datetime    updated_at
}

fee_payments {
    int         id              PK
    int         team_id         FK
    int         user_id         FK
    string      year_month
    boolean     is_paid
    datetime    paid_at
}

%% ─────────────────────────────────────────
%%  4. 경기 투표 & 기록
%% ─────────────────────────────────────────

polls {
    int         id              PK
    int         team_id         FK
    int         created_by      FK
    string      title
    date        match_date
    string      match_time
    string      gather_time
    string      location
    float       location_lat
    float       location_lng
    string      opponent_team
    int         fee
    string      memo
    date        deadline
    string      status
    datetime    created_at
}

poll_votes {
    int         id              PK
    int         poll_id         FK
    int         user_id         FK
    string      vote
    datetime    voted_at
}

matches {
    int         id              PK
    int         team_id         FK
    int         poll_id         FK
    int         created_by      FK
    date        match_date
    string      opponent
    int         my_score
    int         opponent_score
    string      result
    datetime    created_at
    datetime    updated_at
}

match_players {
    int         id              PK
    int         match_id        FK
    int         user_id         FK
    string      guest_name
}

match_goals {
    int         id              PK
    int         match_id        FK
    int         user_id         FK
    string      guest_name
    int         count
}

match_assists {
    int         id              PK
    int         match_id        FK
    int         user_id         FK
    string      guest_name
    int         count
}

mvp_votes {
    int         id              PK
    int         match_id        FK
    int         voter_id        FK
    int         candidate_id    FK
    datetime    voted_at
}

match_videos {
    int         id              PK
    int         match_id        FK
    int         uploaded_by     FK
    string      youtube_url
    string      thumbnail
    string      title
    datetime    created_at
}

video_comments {
    int         id              PK
    int         video_id        FK
    int         author_id       FK
    string      content
    datetime    created_at
}

%% ─────────────────────────────────────────
%%  5. 용병 & 매너 점수
%% ─────────────────────────────────────────

mercenary_posts {
    int         id              PK
    int         author_id       FK
    string      type
    string      position
    date        available_date
    string      available_time
    string      location
    string      level
    string      description
    string      status
    datetime    created_at
    datetime    expires_at
}

mercenary_applications {
    int         id              PK
    int         post_id         FK
    int         applicant_id    FK
    string      status
    datetime    applied_at
    datetime    processed_at
}

match_evaluations {
    int         id              PK
    int         match_id        FK
    int         evaluator_id    FK
    int         target_id       FK
    float       punctuality
    float       skill
    float       attitude
    float       communication
    boolean     is_noshow
    datetime    created_at
}

manner_scores {
    int         id              PK
    int         user_id         FK
    float       total_score
    float       punctuality
    float       skill
    float       attitude
    float       communication
    int         review_count
    datetime    updated_at
}

%% ─────────────────────────────────────────
%%  6. 채팅
%% ─────────────────────────────────────────

chat_rooms {
    int         id              PK
    int         user1_id        FK
    int         user2_id        FK
    datetime    created_at
    datetime    last_message_at
}

chat_messages {
    int         id              PK
    int         room_id         FK
    int         sender_id       FK
    string      content
    boolean     is_read
    datetime    created_at
}

%% ─────────────────────────────────────────
%%  7. 축구장 (정적 데이터)
%% ─────────────────────────────────────────

soccer_fields {
    int         id              PK
    string      name
    string      address
    float       lat
    float       lng
    string      type
    string      size
    string      phone
}

%% ============================================================
%%  관계 정의 (Relationships)
%% ============================================================

%% 인증
users           ||--o{     refresh_tokens       : "발급"
users           ||--o{     fcm_tokens           : "등록"
users           ||--o{     notifications        : "수신"

%% 팀 멤버십
teams           ||--|{     team_members         : "구성"
users           ||--o{     team_members         : "소속"
teams           ||--o{     join_requests        : "접수"
users           ||--o{     join_requests        : "신청"
teams           ||--o{     invite_links         : "생성"
teams           }o--||     users                : "팀장(captain)"

%% 팀 부가 기능
teams           ||--o{     board_posts          : "게시"
users           ||--o{     board_posts          : "작성"
board_posts     ||--o{     post_comments        : "댓글"
users           ||--o{     post_comments        : "작성"
teams           ||--o|     team_fees            : "설정"
teams           ||--o{     fee_payments         : "관리"
users           ||--o{     fee_payments         : "납부"

%% 경기 투표
teams           ||--o{     polls                : "생성"
users           ||--o{     polls                : "생성"
polls           ||--o{     poll_votes           : "집계"
users           ||--o{     poll_votes           : "투표"
teams           ||--o|     position_setups      : "저장"
polls           ||--o|     position_setups      : "연결"

%% 경기 기록
teams           ||--o{     matches              : "보유"
polls           ||--o|     matches              : "연결"
users           ||--o{     matches              : "작성"
matches         ||--o{     match_players        : "출전"
users           ||--o{     match_players        : "출전"
matches         ||--o{     match_goals          : "득점"
users           ||--o{     match_goals          : "득점"
matches         ||--o{     match_assists        : "도움"
users           ||--o{     match_assists        : "도움"
matches         ||--o{     mvp_votes            : "투표"
users           ||--o{     mvp_votes            : "투표(voter)"
users           ||--o{     mvp_votes            : "후보(candidate)"
matches         ||--o{     match_videos         : "영상"
users           ||--o{     match_videos         : "업로드"
match_videos    ||--o{     video_comments       : "댓글"
users           ||--o{     video_comments       : "작성"

%% 용병 & 매너
users           ||--o{     mercenary_posts      : "등록"
mercenary_posts ||--o{     mercenary_applications : "지원"
users           ||--o{     mercenary_applications : "지원"
matches         ||--o{     match_evaluations    : "평가"
users           ||--o{     match_evaluations    : "평가(evaluator)"
users           ||--o{     match_evaluations    : "피평가(target)"
users           ||--o|     manner_scores        : "집계"

%% 채팅
users           ||--o{     chat_rooms           : "참여(user1)"
users           ||--o{     chat_rooms           : "참여(user2)"
chat_rooms      ||--o{     chat_messages        : "메시지"
users           ||--o{     chat_messages        : "발송"
